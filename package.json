{
  "name": "sadecv",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-prisma.mjs && next build",
    "admin:grant": "node --env-file=.env scripts/grant-admin.mjs",
    "check": "eslint . && tsc --noEmit",
    "db:generate": "node scripts/prisma.mjs migrate dev",
    "db:generate:client": "node scripts/generate-prisma.mjs",
    "db:generate:postgres": "node scripts/prisma.mjs --provider=postgresql generate",
    "db:migrate": "node scripts/prisma.mjs migrate deploy",
    "db:migrate:postgres": "node scripts/prisma.mjs --provider=postgresql migrate deploy",
    "db:push": "node scripts/prisma.mjs db push",
    "db:push:postgres": "node scripts/prisma.mjs --provider=postgresql db push",
    "db:studio": "node scripts/prisma.mjs studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "node scripts/generate-prisma.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "next build && next start",
    "start": "next start",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "^6.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@uploadthing/react": "^7.3.3",
    "bcryptjs": "^3.0.2",
    "iyzipay": "^2.0.69",
    "lucide-react": "^0.468.0",
    "next": "15.5.20",
    "next-auth": "5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^5.0.1",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "superjson": "^2.2.1",
    "uploadthing": "^7.7.4",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/eslint-plugin-next": "15.5.20",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "15.5.20",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@11.9.0"
}
